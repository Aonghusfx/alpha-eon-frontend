# Alphaeon Backend API Configuration
VITE_ALPHAEON_API_URL=https://alpha-eon-backend.vercel.app/api

# Alphaeon OAuth Credentials
VITE_ALPHAEON_CLIENT_ID=your_client_id_here
VITE_ALPHAEON_CLIENT_SECRET=your_client_secret_here

# Alphaeon Configuration
VITE_ALPHAEON_LOCATION_ID=15470
VITE_ALPHAEON_MERCHANT_ID=your_merchant_id
